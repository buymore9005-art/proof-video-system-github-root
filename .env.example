# Browser-safe values from Supabase Dashboard -> Project Settings -> API Keys.
# VITE_SUPABASE_PUBLISHABLE_KEY starts with sb_publishable_.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Server-only value for Vercel Functions.
# SUPABASE_SECRET_KEY starts with sb_secret_. Never add the VITE_ prefix.
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# One-time protection for creating the first administrator through /#/setup.
# Use a random value with at least 32 characters.
SETUP_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
